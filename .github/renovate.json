{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "schedule": ["before 3am on the first day of the month"],
  "rangeStrategy": "update-lockfile",
  "postUpgradeTasks": {
    "commands": ["cd src/liquidctl_server && uv lock"],
    "fileFilters": ["src/liquidctl_server/uv.lock"],
    "executionMode": "update"
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^src/liquidctl_server/pyproject\\.toml$"],
      "matchStrings": [
        "liquidctl\\s*@\\s*git\\+https://github\\.com/[^/]+/[^/\\s]+?(?:\\.git)?@(?<currentDigest>[a-f0-9]+)"
      ],
      "currentValueTemplate": "main",
      "packageNameTemplate": "https://github.com/liquidctl/liquidctl",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "liquidctl/liquidctl",
      "depTypeTemplate": "dependencies"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchDepTypes": ["dependencies"],
      "semanticCommitType": "deps",
      "semanticCommitScope": null
    },
    {
      "matchDatasources": ["git-refs"],
      "matchUpdateTypes": ["digest"],
      "commitMessageAction": "bump",
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "to {{newDigestShort}}",
      "changelogUrl": "{{{packageName}}}/compare/{{currentDigest}}...{{newDigest}}",
      "commitBody": "Changelog: {{{packageName}}}/compare/{{currentDigest}}...{{newDigest}}"
    }
  ]
}
